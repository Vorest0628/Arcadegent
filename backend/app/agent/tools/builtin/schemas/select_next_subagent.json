{
  "name": "select_next_subagent",
  "kind": "function",
  "description": "Emit a compatibility hint for next subagent candidate; runtime policy decides final route.",
  "executor": "app.agent.tools.builtin.executors.select_next_subagent:execute",
  "capabilities": ["builtin", "read_only", "orchestration"],
  "metadata": {
    "tool_function": "app.agent.tools.builtin.executors.select_next_subagent:execute"
  },
  "input_schema": {
    "additionalProperties": false,
    "properties": {
      "current_subagent": {
        "title": "Current Subagent",
        "type": "string"
      },
      "intent": {
        "anyOf": [{ "type": "string" }, { "type": "null" }],
        "title": "Intent"
      },
      "tool_name": {
        "anyOf": [{ "type": "string" }, { "type": "null" }],
        "title": "Tool Name"
      },
      "tool_status": {
        "enum": ["completed", "failed"],
        "title": "Tool Status",
        "type": "string"
      },
      "has_route": {
        "title": "Has Route",
        "type": "boolean"
      },
      "has_shops": {
        "title": "Has Shops",
        "type": "boolean"
      }
    },
    "required": [
      "current_subagent",
      "intent",
      "tool_name",
      "tool_status",
      "has_route",
      "has_shops"
    ],
    "title": "SelectNextSubagentArgs",
    "type": "object"
  }
}
